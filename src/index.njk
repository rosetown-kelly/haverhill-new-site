---
layout: layouts/base.njk
title: "Commercial Real Estate Listings – Haverhill"
description: "View current commercial real estate listings from Haverhill Business Enterprises Ltd."
---

<div class="home-listings-page">
  <div class="listings-container">
    <h2>Haverhill's Current Listings</h2>

    {% for listing in listings %}
      <div class="listing-card">
        <img src="{{ listing.heroImage or listing.galleryImages[0] }}" alt="{{ listing.name }}">
        <div class="listing-info">
          <h3>{{ listing.name }}</h3>
          <p>{{ listing.address }}</p>
          <span class="status">{{ listing.status }}</span>
          <p>Available Area: {{ listing.availableArea or listing.squareFootage }}</p>
          <p>Property Type: {{ listing.propertyType }}</p>
          <p>Zoning: {{ listing.zoning or listing.type }}</p>
          {% if listing.salePrice %}
            <p>Sale Price: {{ listing.salePrice }}</p>
          {% endif %}
          {% if listing.leaseNote %}
            <p>{{ listing.leaseNote }}</p>
          {% endif %}
          <a href="/{{ listing.slug }}/">View Full Details →</a>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
